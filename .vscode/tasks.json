{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build_release",
      "type": "shell",
      "command": ".\\build.ps1",
      "args": [
        "-Static"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "build_release_rebuild",
      "type": "shell",
      "command": ".\\build.ps1",
      "args": [
        "-Static",
        "-Rebuild"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run_radioify",
      "type": "shell",
      "command": ".\\dist\\radioify.exe",
      "args": [
        "${input:radioifyPath}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "radioifyPath",
      "type": "promptString",
      "description": "File or folder to open with radioify",
      "default": "C:\\Users\\boazp\\Music\\"
    }
  ]
}
