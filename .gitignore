# .gitignore voor Visual Studio C++ (CMake) project

# Visual Studio
.vs/
.vscode/*
!.vscode/tasks.json
.codex
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
ipch/
*.aps
*.ncb
*.opendb
*.opensdf

# Build artifacts
[Bb]in/
[Oo]bj/
build/
build-gcc/
build-*/
!scripts/build/
!scripts/build/**
!scripts/build/**/*.ps1
cmake-build-*/
cmake-build*/
vcpkg_installed*/

# CMake files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Testing/
Makefile
compile_commands.json
install_manifest.txt
CPackConfig.cmake
CPackSourceConfig.cmake
*_CPack_Packages/

# Visual C++ intermediate and binary files
*.obj
*.o
*.idb
*.pdb
*.ipdb
*.ilk
*.iobj
*.ipch
*.pch
*.lib
*.dll
*.exe
*.manifest
*.exp

# Other
# *.log
*.vsconfig
*.userprefs

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Temp files
*~
*.swp
*.swo
*.tmp
*.temp
*.bak
*.orig
*.rej
tmp/
temp/
audio/audiofilter/tmp/
**.dmp
**.txt
**.log

# Package managers and caches
node_modules/
packages/
.vcpkg/
.vcpkg_installed/
__pycache__/

# CPack artifacts
*.tar.gz
*.zip
*.7z

# Keep CMakeLists, source, headers, and project files tracked
# (Adjust as needed for any generated sources you want to ignore)

**.webm
models/*.onnx
models/*.download

# Useless files
**.md
!README.md
!BUILD_WINDOWS.md

# Output files
**.melody
**.mid
**.wav
**.mp3
**.flac
**.pyc
**.rmi
