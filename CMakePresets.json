{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "cacheVariables": {
        "VCPKG_MANIFEST_MODE": {
          "type": "BOOL",
          "value": "OFF"
        },
        "VCPKG_MANIFEST_INSTALL": {
          "type": "BOOL",
          "value": "OFF"
        }
      }
    },
    {
      "name": "windows-static-base",
      "hidden": true,
      "inherits": "windows-base",
      "cacheVariables": {
        "VCPKG_APPLOCAL_DEPS": {
          "type": "BOOL",
          "value": "OFF"
        }
      }
    },
    {
      "name": "windows-ninja-base",
      "hidden": true,
      "inherits": "windows-base",
      "generator": "Ninja"
    },
    {
      "name": "windows-clangcl-base",
      "hidden": true,
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_C_FLAGS_INIT": "/clang:-fcolor-diagnostics /clang:-fansi-escape-codes /clang:-fcommon",
        "CMAKE_CXX_FLAGS_INIT": "/clang:-fcolor-diagnostics /clang:-fansi-escape-codes",
        "CMAKE_RC_COMPILER": "rc",
        "CMAKE_MT": "mt"
      }
    },
    {
      "name": "windows-default",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "windows-static",
      "inherits": "windows-static-base",
      "binaryDir": "${sourceDir}/build-static"
    },
    {
      "name": "windows-ninja",
      "inherits": "windows-ninja-base",
      "binaryDir": "${sourceDir}/build-ninja"
    },
    {
      "name": "windows-ninja-static",
      "inherits": [
        "windows-ninja-base",
        "windows-static-base"
      ],
      "binaryDir": "${sourceDir}/build-ninja-static"
    },
    {
      "name": "windows-clangcl",
      "inherits": "windows-clangcl-base",
      "binaryDir": "${sourceDir}/build-clangcl"
    },
    {
      "name": "windows-clangcl-static",
      "inherits": [
        "windows-clangcl-base",
        "windows-static-base"
      ],
      "binaryDir": "${sourceDir}/build-clangcl-static"
    },
    {
      "name": "windows-ninja-clangcl",
      "inherits": [
        "windows-ninja-base",
        "windows-clangcl-base"
      ],
      "binaryDir": "${sourceDir}/build-ninja-clangcl"
    },
    {
      "name": "windows-ninja-clangcl-static",
      "inherits": [
        "windows-ninja-base",
        "windows-clangcl-base",
        "windows-static-base"
      ],
      "binaryDir": "${sourceDir}/build-ninja-clangcl-static"
    }
  ],
  "buildPresets": [
    {
      "name": "windows-default",
      "configurePreset": "windows-default",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-static",
      "configurePreset": "windows-static",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-ninja",
      "configurePreset": "windows-ninja",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-ninja-static",
      "configurePreset": "windows-ninja-static",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-clangcl",
      "configurePreset": "windows-clangcl",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-clangcl-static",
      "configurePreset": "windows-clangcl-static",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-ninja-clangcl",
      "configurePreset": "windows-ninja-clangcl",
      "targets": [
        "radioify"
      ]
    },
    {
      "name": "windows-ninja-clangcl-static",
      "configurePreset": "windows-ninja-clangcl-static",
      "targets": [
        "radioify"
      ]
    }
  ]
}
